# ---------------------------
# MATRIX TOPPER (Self-check + Timed Rain) — FINAL (drop-in)
# - Best-effort self-install: python3 via apt-get (only if missing)
# - Never exits the parent script; always returns 0
# - Renders to /dev/tty so visuals still show with tee logging
# ---------------------------
MATRIX_ENABLED="${MATRIX_ENABLED:-1}"        # 1=on, 0=off
MATRIX_SECONDS="${MATRIX_SECONDS:-10}"      # rain duration
MATRIX_COUNTDOWN="${MATRIX_COUNTDOWN:-5}"   # countdown seconds (0 disables)
MATRIX_TTY="${MATRIX_TTY:-/dev/tty}"        # render target

matrix_ok() { [ "$MATRIX_ENABLED" = "1" ] && [ -w "$MATRIX_TTY" ]; }

matrix_need_python() { command -v python3 >/dev/null 2>&1; }

matrix_try_install_python() {
  # best-effort only; must not break the main script
  command -v apt-get >/dev/null 2>&1 || return 1
  command -v sudo    >/dev/null 2>&1 || return 1

  # get sudo (non-fatal)
  sudo -n true >/dev/null 2>&1 || sudo -v || return 1

  sudo env DEBIAN_FRONTEND=noninteractive DEBCONF_NONINTERACTIVE_SEEN=true \
    apt-get update -y >/dev/null 2>&1 || true

  sudo env DEBIAN_FRONTEND=noninteractive DEBCONF_NONINTERACTIVE_SEEN=true \
    apt-get install -y python3 >/dev/null 2>&1 || return 1

  return 0
}

matrix_countdown() {
  local n="$1"
  [[ "$n" =~ ^[0-9]+$ ]] || return 0
  [ "$n" -gt 0 ] || return 0
  for ((i=n; i>=1; i--)); do
    printf "\033[32mMatrix init in %s...\033[0m\n" "$i" >"$MATRIX_TTY"
    sleep 1
  done
}

matrix_rain_py() {
  local secs="$1"
  python3 - <<PY >"$MATRIX_TTY" 2>/dev/null
import sys,time,random,shutil
secs=float("${secs}")
w,h = shutil.get_terminal_size((80,24))
green="\033[32m"; reset="\033[0m"
clear="\033[2J\033[H"; hide="\033[?25l"; show="\033[?25h"

sys.stdout.write(clear+hide); sys.stdout.flush()

end=time.time()+secs
cols=[random.randint(1,h) for _ in range(w)]

while time.time()<end:
    for _ in range(max(80,w)):
        x=random.randrange(w)+1
        y=cols[x-1]
        ch=random.choice("01")
        sys.stdout.write(f"\033[{y};{x}H{green}{ch}{reset}")
        cols[x-1]+=1
        if cols[x-1]>h:
            cols[x-1]=1
    sys.stdout.flush()
    time.sleep(0.015)

sys.stdout.write(show+"\n")
sys.stdout.flush()
PY
}

matrix_topper() {
  matrix_ok || return 0

  # ensure cursor is restored even if interrupted
  trap 'printf "\033[?25h\n" >"$MATRIX_TTY" 2>/dev/null || true' RETURN

  # 1) ensure python exists (best effort)
  if ! matrix_need_python; then
    matrix_try_install_python || return 0
    matrix_need_python || return 0
  fi

  # 2) countdown (optional)
  matrix_countdown "$MATRIX_COUNTDOWN"

  # 3) timed rain
  matrix_rain_py "$MATRIX_SECONDS" || true

  return 0
}

