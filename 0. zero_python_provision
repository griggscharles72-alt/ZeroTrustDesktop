    print_final_report(s)


# ============================================================================
# CLI
# ============================================================================

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="zero_python_provision.py",
        description="Resilient Debian/Ubuntu Python-first provisioner",
    )

    parser.add_argument("--version", action="store_true", help="Print version and exit")
    parser.add_argument("--json", action="store_true", dest="json_stdout", help="Emit JSON lines to stdout")
    parser.add_argument("--yes", action="store_true", help="Pass -y to apt install/upgrade")
    parser.add_argument("--dry-run", action="store_true", help="Log actions without changing the system")

    sub = parser.add_subparsers(dest="cmd", required=False)

    b = sub.add_parser("bootstrap", help="Provision packages from a profile")
    b.add_argument("--profile", choices=["dev", "secure", "full"], default="dev")
    b.add_argument("--upgrade", action="store_true")
    b.add_argument("--python-link", action="store_true", help="Install python-is-python3 if python command is missing")
    b.add_argument("--pipx-tools", action="store_true")
    b.add_argument("--venv", action="store_true")
    b.add_argument("--venv-libs", action="store_true")
    b.add_argument("--enable-services", action="store_true")
    b.add_argument("--firewall-baseline", action="store_true")
    b.add_argument("--disable-printing", action="store_true")

    py = sub.add_parser("python", help="Python-only install flow")
    py.add_argument("--upgrade", action="store_true")
    py.add_argument("--python-link", action="store_true", help="Install python-is-python3 if python command is missing")
    py.add_argument("--pipx-tools", action="store_true")
    py.add_argument("--venv", action="store_true")
    py.add_argument("--venv-libs", action="store_true")

    sub.add_parser("verify", help="Verify installed tooling and service status")
    sub.add_parser("report", help="Print/write current run summary only")

    return parser


def make_settings(args: argparse.Namespace) -> Settings:
    if not getattr(args, "dry_run", False):
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        REPORT_DIR.mkdir(parents=True, exist_ok=True)

    return Settings(
        yes=bool(args.yes),
        json_stdout=bool(args.json_stdout),
        dry_run=bool(args.dry_run),
        profile=str(getattr(args, "profile", "dev")),
        upgrade=bool(getattr(args, "upgrade", False)),
        python_link=bool(getattr(args, "python_link", False)),
        pipx_tools=bool(getattr(args, "pipx_tools", False)),
        venv=bool(getattr(args, "venv", False)),
        venv_libs=bool(getattr(args, "venv_libs", False)),
        enable_services=bool(getattr(args, "enable_services", False)),
        firewall_baseline=bool(getattr(args, "firewall_baseline", False)),
        disable_printing=bool(getattr(args, "disable_printing", False)),
        log_file=DEFAULT_LOG_FILE,
        report_file=DEFAULT_REPORT_FILE,
    )


# ============================================================================
# Main
# ============================================================================

def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if args.version:
        print(f"{APP_NAME} {VERSION}")
        return 0

    settings = make_settings(args)

    try:
        cmd = args.cmd or "bootstrap"
        if cmd == "bootstrap":
            cmd_bootstrap(settings)
        elif cmd == "python":
            cmd_python(settings)
        elif cmd == "verify":
            cmd_verify(settings)
        elif cmd == "report":
            cmd_report(settings)
        else:
            err(settings, f"Unknown command: {cmd}")
            write_summary_report(settings)
            print_final_report(settings)
            return 2
    except KeyboardInterrupt:
        err(settings, "Interrupted by user")
        write_summary_report(settings)
        print_final_report(settings)
        return 130
    except SystemExit:
        raise
    except Exception as exc:
        err(
            settings,
            "Fatal exception in main",
            {
                "exception": repr(exc),
                "traceback": traceback.format_exc(),
            },
        )
        write_summary_report(settings)
        print_final_report(settings)
        return 1

    return 0 if not STATE.errors else 1


if __name__ == "__main__":
    sys.exit(main())
