# ============================================================================
# Data
# ============================================================================

@dataclass
class Settings:
    yes: bool
    json_stdout: bool
    dry_run: bool
    profile: str
    upgrade: bool
    python_link: bool
    pipx_tools: bool
    venv: bool
    venv_libs: bool
    enable_services: bool
    firewall_baseline: bool
    disable_printing: bool
    log_file: Path
    report_file: Path


@dataclass
class Event:
    ts: str
    level: str
    msg: str
    data: Optional[dict] = None


@dataclass
class CommandResult:
    rc: int
    stdout: str
    stderr: str


@dataclass
class SectionResult:
    name: str
    status: str
    started_at: str
    ended_at: str
    error_count: int
    warning_count: int


class RuntimeState:
    def __init__(self) -> None:
        self.section_stack: List[str] = []
        self.section_results: List[SectionResult] = []
        self.errors: List[dict] = []
        self.warnings: List[dict] = []
        self.command_count = 0
        self.command_failures = 0

    def current_section(self) -> str:
        return self.section_stack[-1] if self.section_stack else "global"


STATE = RuntimeState()


# ============================================================================
# Logging
# ============================================================================

def now_ts() -> str:
    return datetime.now().isoformat(timespec="seconds")


def ensure_parent(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)


def append_text(path: Path, text: str) -> None:
    ensure_parent(path)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(text)


def emit(s: Settings, level: str, msg: str, data: Optional[dict] = None) -> None:
    event = Event(ts=now_ts(), level=level, msg=msg, data=data)
    record = asdict(event)

    if s.json_stdout:
        print(json.dumps(record, ensure_ascii=False))
    else:
        line = f"[{event.ts}] {event.level}: {event.msg}"
        if data:
            line += f" | {json.dumps(data, ensure_ascii=False, sort_keys=True)}"
        print(line)

    try:
        append_text(s.log_file, json.dumps(record, ensure_ascii=False) + "\n")
    except Exception:
        print(f"[{event.ts}] ERROR: failed to write log file", file=sys.stderr)


def info(s: Settings, msg: str, data: Optional[dict] = None) -> None:
    emit(s, "INFO", msg, data)


def warn(s: Settings, msg: str, data: Optional[dict] = None) -> None:
    STATE.warnings.append(
        {
            "section": STATE.current_section(),
            "msg": msg,
            "data": data or {},
            "ts": now_ts(),
        }
    )
    emit(s, "WARN", msg, data)


def err(s: Settings, msg: str, data: Optional[dict] = None) -> None:
    STATE.errors.append(
        {
            "section": STATE.current_section(),
            "msg": msg,
            "data": data or {},
            "ts": now_ts(),
        }
    )
    emit(s, "ERROR", msg, data)


# ============================================================================
# Helpers
# ============================================================================

def have(cmd: str) -> bool:
    return shutil.which(cmd) is not None


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return ""


def run_command(
    s: Settings,
    cmd: Sequence[str],
    *,
    check: bool = False,
    sudo: bool = False,
    timeout: int = DEFAULT_COMMAND_TIMEOUT,
    extra_env: Optional[Dict[str, str]] = None,
) -> CommandResult:
    full_cmd = ["sudo", *cmd] if sudo else list(cmd)
    STATE.command_count += 1

    info(
        s,
        "Running command",
        {
            "section": STATE.current_section(),
            "cmd": full_cmd,
            "dry_run": s.dry_run,
            "timeout_sec": timeout,
        },
    )

    if s.dry_run:
        return CommandResult(rc=0, stdout="", stderr="")

    env = None
    if extra_env:
        env = {**os.environ, **extra_env}

    try:
        proc = subprocess.run(
            full_cmd,
            text=True,
            capture_output=True,
            timeout=timeout,
            env=env,
        )
    except FileNotFoundError as exc:
        STATE.command_failures += 1
        err(s, "Command executable not found", {"cmd": full_cmd, "exception": repr(exc)})
        if check:
            raise
        return CommandResult(rc=127, stdout="", stderr=str(exc))
    except subprocess.TimeoutExpired as exc:
        STATE.command_failures += 1
        err(
            s,
            "Command timed out",
            {
                "cmd": full_cmd,
                "timeout_sec": timeout,
                "stdout_first": ((exc.stdout or "").strip().splitlines()[:1] or [""])[0],
                "stderr_first": ((exc.stderr or "").strip().splitlines()[:1] or [""])[0],
            },
        )
        if check:
            raise RuntimeError(f"Command timed out: {' '.join(full_cmd)}")
        return CommandResult(rc=124, stdout=exc.stdout or "", stderr=exc.stderr or "")
    except Exception as exc:
        STATE.command_failures += 1
        err(s, "Command execution exception", {"cmd": full_cmd, "exception": repr(exc)})
        if check:
            raise
        return CommandResult(rc=1, stdout="", stderr=str(exc))

    result = CommandResult(
        rc=proc.returncode,
        stdout=proc.stdout or "",
        stderr=proc.stderr or "",
    )

    preview = {
        "rc": result.rc,
        "stdout_first": (result.stdout.strip().splitlines()[:1] or [""])[0],
        "stderr_first": (result.stderr.strip().splitlines()[:1] or [""])[0],
    }

    if result.rc == 0:
        info(s, "Command succeeded", preview)
    else:
        STATE.command_failures += 1
        err(s, "Command failed", {"cmd": full_cmd, **preview})
        if check:
            raise RuntimeError(f"Command failed: {' '.join(full_cmd)} (rc={result.rc})")

    return result


def apt_run(s: Settings, args: Sequence[str], *, check: bool = False) -> CommandResult:
    return run_command(
        s,
        ["apt-get", *args],
        sudo=True,
        check=check,
        timeout=DEFAULT_COMMAND_TIMEOUT,
        extra_env=APT_ENV,
    )


def dpkg_installed(pkg: str) -> bool:
    proc = subprocess.run(
        ["dpkg-query", "-W", "-f=${Status}", pkg],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    return proc.returncode == 0 and "install ok installed" in (proc.stdout or "")


def systemd_unit_exists(s: Settings, name: str) -> bool:
    if not have("systemctl"):
        return False

    result = run_command(
        s,
        ["systemctl", "list-unit-files", f"{name}.service", "--no-legend", "--no-pager"],
        check=False,
        timeout=SHORT_COMMAND_TIMEOUT,
    )
    if result.rc == 0 and f"{name}.service" in result.stdout:
        return True

    candidates = [
        Path("/etc/systemd/system") / f"{name}.service",
        Path("/lib/systemd/system") / f"{name}.service",
        Path("/usr/lib/systemd/system") / f"{name}.service",
    ]
    return any(path.exists() for path in candidates)


def require_debian_like(s: Settings) -> None:
    ok = Path("/etc/os-release").exists() and have("apt-get") and have("dpkg-query")
    if not ok:
        err(
            s,
            "Unsupported platform",
            {
                "required": "Debian/Ubuntu with apt-get and dpkg-query",
                "have_apt_get": have("apt-get"),
                "have_dpkg_query": have("dpkg-query"),
                "os_release_exists": Path("/etc/os-release").exists(),
            },
        )
        raise SystemExit(2)

    os_release = read_text(Path("/etc/os-release")).lower()
    if "debian" not in os_release and "ubuntu" not in os_release:
        warn(s, "OS is not explicitly Debian/Ubuntu; continuing because apt-get exists")


def preflight_apt_health(s: Settings) -> None:
    info(s, "Checking dpkg audit state")
    run_command(s, ["dpkg", "--audit"], check=False, timeout=SHORT_COMMAND_TIMEOUT)


# ============================================================================
# Section runner
# ============================================================================

def run_section(
    s: Settings,
    name: str,
    fn: Callable[..., None],
    *args,
    **kwargs,
) -> None:
    started = now_ts()
    STATE.section_stack.append(name)
    errors_before = len(STATE.errors)
    warnings_before = len(STATE.warnings)
    status = "ok"

    info(s, f"SECTION START: {name}")
    try:
        fn(*args, **kwargs)
    except Exception as exc:
        status = "failed"
        err(
            s,
            f"Section exception: {name}",
            {
                "exception": repr(exc),
                "traceback": traceback.format_exc(),
            },
        )
    finally:
        ended = now_ts()
        STATE.section_results.append(
            SectionResult(
                name=name,
                status=status,
                started_at=started,
                ended_at=ended,
                error_count=len(STATE.errors) - errors_before,
                warning_count=len(STATE.warnings) - warnings_before,
            )
        )
        info(
            s,
            f"SECTION END: {name}",
            {
                "status": status,
                "errors": len(STATE.errors) - errors_before,
                "warnings": len(STATE.warnings) - warnings_before,
            },
        )
        STATE.section_stack.pop()


# ============================================================================
# Package operations
# ============================================================================

def apt_update(s: Settings) -> None:
    apt_run(s, ["update"], check=False)


def apt_upgrade(s: Settings) -> None:
    args: List[str] = []
    if s.yes:
        args.append("-y")
    args.append("upgrade")
    apt_run(s, args, check=False)


def apt_install_missing(s: Settings, pkgs: Iterable[str]) -> None:
    requested = list(dict.fromkeys(pkgs))
    missing = [pkg for pkg in requested if not dpkg_installed(pkg)]

    for pkg in requested:
        if pkg in missing:
            info(s, "Package missing", {"package": pkg})
        else:
            info(s, "Package already installed", {"package": pkg})

    if not missing:
        info(s, "No missing packages in this section")
        return

    args: List[str] = []
    if s.yes:
        args.append("-y")
    args.extend(["install", *missing])
    apt_run(s, args, check=False)


# ============================================================================
# File / shell
# ============================================================================

def ensure_local_bin_path(s: Settings) -> None:
    local_bin = HOME / ".local" / "bin"
    if not s.dry_run:
        local_bin.mkdir(parents=True, exist_ok=True)

    bashrc = HOME / ".bashrc"
    export_line = 'export PATH="$HOME/.local/bin:$PATH"'
    content = read_text(bashrc)

    if export_line in content:
        info(s, "~/.local/bin already present in ~/.bashrc")
        return

    backup = HOME / f".bashrc.{APP_ID}.bak"
    if bashrc.exists() and not backup.exists() and not s.dry_run:
        backup.write_text(content, encoding="utf-8")
        info(s, "Created ~/.bashrc backup", {"backup": str(backup)})

    if not s.dry_run:
        append_text(bashrc, "\n" + export_line + "\n")
    info(s, "Appended ~/.local/bin to ~/.bashrc")


# ============================================================================
# Python / pipx / venv
# ============================================================================

def ensure_python_alias_package(s: Settings) -> None:
    if not s.python_link:
        info(s, "python alias not requested")
        return

    if have("python"):
        info(s, "python already exists on PATH")
        return

    info(s, "Ensuring python command via python-is-python3 package")
    apt_install_missing(s, PKGS_PY_ALIAS)


def pipx_ensurepath(s: Settings) -> None:
    if not have("pipx"):
        warn(s, "pipx not found; skipping pipx ensurepath")
        return
    run_command(s, ["pipx", "ensurepath"], check=False, timeout=SHORT_COMMAND_TIMEOUT)


def pipx_install_tools(s: Settings) -> None:
    if not s.pipx_tools:
        info(s, "pipx tools not requested")
        return

    if not have("pipx"):
        warn(s, "pipx not found; cannot install pipx tools")
        return

    for tool in PIPX_TOOLS:
        run_command(s, ["pipx", "install", tool], check=False, timeout=DEFAULT_COMMAND_TIMEOUT)


def ensure_default_venv(s: Settings) -> None:
    if not s.venv:
        info(s, "venv creation not requested")
        return

    venv_python = PY_DEFAULT_VENV / "bin" / "python"
    if venv_python.exists():
        info(s, "Default venv already exists", {"path": str(PY_DEFAULT_VENV)})
        return

    if not have("python3"):
        err(s, "python3 missing; cannot create venv")
        return

    if not s.dry_run:
        PY_WORKDIR.mkdir(parents=True, exist_ok=True)

    run_command(
        s,
        ["python3", "-m", "venv", str(PY_DEFAULT_VENV)],
        check=False,
        timeout=DEFAULT_COMMAND_TIMEOUT,
    )


def install_venv_libs(s: Settings) -> None:
    if not s.venv_libs:
        info(s, "venv libs not requested")
        return

    pip_bin = PY_DEFAULT_VENV / "bin" / "pip"
    if not pip_bin.exists():
        warn(s, "Default venv pip not found; skipping venv libs install")
        return

    run_command(
        s,
        [str(pip_bin), "install", "--upgrade", *VENV_LIBS],
        check=False,
        timeout=DEFAULT_COMMAND_TIMEOUT,
    )


# ============================================================================
# Services / firewall
# ============================================================================

def enable_requested_services(s: Settings) -> None:
    if not s.enable_services:
        info(s, "service enablement not requested")
        return

    if not have("systemctl"):
        warn(s, "systemctl not found; cannot enable services")
        return

    services = ["ufw", "fail2ban", "auditd", "tor", "nginx"]
    for svc in services:
        if not systemd_unit_exists(s, svc):
            warn(s, "Service unit not found; skipping enable", {"service": svc})
            continue
        run_command(
            s,
            ["systemctl", "enable", "--now", svc],
            sudo=True,
            check=False,
            timeout=SHORT_COMMAND_TIMEOUT,
        )


def apply_firewall_baseline(s: Settings) -> None:
    if not s.firewall_baseline:
        info(s, "firewall baseline not requested")
        return

    if not have("ufw"):
        warn(s, "ufw not found; cannot apply firewall baseline")
        return

    run_command(s, ["ufw", "allow", "OpenSSH"], sudo=True, check=False, timeout=SHORT_COMMAND_TIMEOUT)
    run_command(s, ["ufw", "--force", "enable"], sudo=True, check=False, timeout=SHORT_COMMAND_TIMEOUT)


def disable_printing_services(s: Settings) -> None:
    if not s.disable_printing:
        info(s, "printing disable not requested")
        return

    if not have("systemctl"):
        warn(s, "systemctl not found; cannot disable printing services")
        return

    for svc in ["cups", "cups-browsed"]:
        if not systemd_unit_exists(s, svc):
            warn(s, "Printing service unit not found; skipping", {"service": svc})
            continue
        run_command(
            s,
            ["systemctl", "disable", "--now", svc],
            sudo=True,
            check=False,
            timeout=SHORT_COMMAND_TIMEOUT,
        )


# ============================================================================
# Verification
# ============================================================================

def verify_environment(s: Settings) -> None:
    info(
        s,
        "Verification started",
        {
            "app": APP_NAME,
            "app_id": APP_ID,
            "version": VERSION,
            "python_runtime": sys.version.splitlines()[0],
        },
    )

    checks: Dict[str, List[str]] = {
        "python3": ["python3", "--version"],
        "pip3": ["pip3", "--version"],
        "pipx": ["pipx", "--version"],
        "gcc": ["gcc", "--version"],
        "git": ["git", "--version"],
    }

    optional_checks: Dict[str, List[str]] = {
        "python": ["python", "--version"],
    }

    for exe, cmd in checks.items():
        if not have(exe):
            err(s, "Required command missing", {"command": exe})
            continue
        run_command(s, cmd, check=False, timeout=SHORT_COMMAND_TIMEOUT)

    for exe, cmd in optional_checks.items():
        if not have(exe):
            warn(s, "Optional command missing", {"command": exe})
            continue
        run_command(s, cmd, check=False, timeout=SHORT_COMMAND_TIMEOUT)

    if have("ufw"):
        run_command(s, ["ufw", "status"], sudo=True, check=False, timeout=SHORT_COMMAND_TIMEOUT)

    if have("systemctl"):
        run_command(s, ["systemctl", "--failed", "--no-pager"], check=False, timeout=SHORT_COMMAND_TIMEOUT)
    else:
        warn(s, "systemctl missing; cannot inspect failed services")


# ============================================================================
# Reports
# ============================================================================

def build_summary(s: Settings) -> dict:
    return {
        "app": APP_NAME,
        "app_id": APP_ID,
        "version": VERSION,
        "run_id": RUN_ID,
        "generated_at": now_ts(),
        "log_file": str(s.log_file),
        "report_file": str(s.report_file),
        "settings": {
            "yes": s.yes,
            "json_stdout": s.json_stdout,
            "dry_run": s.dry_run,
            "profile": s.profile,
            "upgrade": s.upgrade,
            "python_link": s.python_link,
            "pipx_tools": s.pipx_tools,
            "venv": s.venv,
            "venv_libs": s.venv_libs,
            "enable_services": s.enable_services,
            "firewall_baseline": s.firewall_baseline,
            "disable_printing": s.disable_printing,
        },
        "commands": {
            "count": STATE.command_count,
            "failures": STATE.command_failures,
        },
        "sections": [asdict(item) for item in STATE.section_results],
        "errors": STATE.errors,
        "warnings": STATE.warnings,
        "status": "ok" if not STATE.errors else "completed_with_errors",
    }


def write_summary_report(s: Settings) -> None:
    summary = build_summary(s)
    try:
        ensure_parent(s.report_file)
        if not s.dry_run:
            s.report_file.write_text(
                json.dumps(summary, indent=2, ensure_ascii=False),
                encoding="utf-8",
            )
        info(s, "Summary report written", {"path": str(s.report_file)})
    except Exception as exc:
        err(s, "Failed to write summary report", {"exception": repr(exc), "path": str(s.report_file)})


def print_final_report(s: Settings) -> None:
    summary = build_summary(s)

    if s.json_stdout:
        print(json.dumps({"final_report": summary}, ensure_ascii=False))
        return

    print()
    print("=" * 78)
    print(f"{APP_NAME} — FINAL REPORT")
    print("=" * 78)
    print(f"Version:           {VERSION}")
    print(f"Status:            {summary['status']}")
    print(f"Commands run:      {summary['commands']['count']}")
    print(f"Command failures:  {summary['commands']['failures']}")
    print(f"Warnings:          {len(summary['warnings'])}")
    print(f"Errors:            {len(summary['errors'])}")
    print(f"Log file:          {s.log_file}")
    print(f"Summary report:    {s.report_file}")
    print()
    print("Sections:")
    for sec in summary["sections"]:
        print(
            f"  - {sec['name']}: {sec['status']} "
            f"(errors={sec['error_count']}, warnings={sec['warning_count']})"
        )

    if summary["errors"]:
        print()
        print("Errors:")
        for idx, item in enumerate(summary["errors"], 1):
            print(f"  {idx}. [{item['section']}] {item['msg']}")
            if item.get("data"):
                print(f"     {json.dumps(item['data'], ensure_ascii=False)}")

    if summary["warnings"]:
        print()
        print("Warnings:")
        for idx, item in enumerate(summary["warnings"], 1):
            print(f"  {idx}. [{item['section']}] {item['msg']}")
            if item.get("data"):
                print(f"     {json.dumps(item['data'], ensure_ascii=False)}")

    print("=" * 78)


# ============================================================================
# Profiles
# ============================================================================

def profile_packages(profile: str) -> List[str]:
    profile = profile.lower()
    if profile == "dev":
        return [*PKGS_CORE, *PKGS_BUILD, *PKGS_PY]
    if profile == "secure":
        return [*PKGS_CORE, *PKGS_BUILD, *PKGS_PY, *PKGS_SEC]
    if profile == "full":
        return [*PKGS_CORE, *PKGS_BUILD, *PKGS_PY, *PKGS_SEC, *PKGS_NET]
    return [*PKGS_PY]


# ============================================================================
# Commands
# ============================================================================

def cmd_bootstrap(s: Settings) -> None:
    require_debian_like(s)

    info(s, "Bootstrap start", {"profile": s.profile, "version": VERSION})

    run_section(s, "preflight_apt_health", preflight_apt_health, s)
    run_section(s, "apt_update", apt_update, s)

    if s.upgrade:
        run_section(s, "apt_upgrade", apt_upgrade, s)

    run_section(s, "apt_install_profile_packages", apt_install_missing, s, profile_packages(s.profile))
    run_section(s, "ensure_local_bin_path", ensure_local_bin_path, s)
    run_section(s, "ensure_python_alias_package", ensure_python_alias_package, s)
    run_section(s, "pipx_ensurepath", pipx_ensurepath, s)
    run_section(s, "pipx_install_tools", pipx_install_tools, s)
    run_section(s, "ensure_default_venv", ensure_default_venv, s)
    run_section(s, "install_venv_libs", install_venv_libs, s)
    run_section(s, "enable_requested_services", enable_requested_services, s)
    run_section(s, "apply_firewall_baseline", apply_firewall_baseline, s)
    run_section(s, "disable_printing_services", disable_printing_services, s)
    run_section(s, "verify_environment", verify_environment, s)

    write_summary_report(s)
    print_final_report(s)


def cmd_python(s: Settings) -> None:
