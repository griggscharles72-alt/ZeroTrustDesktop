# =========================================================

def run_ghost_topper_safe(
    total_seconds: float = 10.0,
    countdown: int = 5,
    design: str = "random",
    title: str = "GHOST PROTOCOL",
) -> None:
    """
    Safest practical topper.
    Returns cleanly without affecting the rest of the script.

    total_seconds:
        Approximate total runtime target.

    countdown:
        Countdown seconds shown before animation.

    design:
        One of the 20 design keys or "random".

    title:
        Title displayed during countdown.
    """
    if not _is_safe_interactive_terminal():
        return

    width, height = _term_size()
    countdown = max(1, countdown)
    total_seconds = max(2.0, total_seconds)

    try:
        if design == "random":
            selected_key = random.choice(list(DESIGNS.keys()))
        else:
            selected_key = design.strip().lower()

        if selected_key not in DESIGNS:
            selected_key = "matrix"

        design_name, design_func = DESIGNS[selected_key]

        # reserve time for countdown + tiny intro/outro
        prelude_sleep = 0.35
        post_countdown_sleep = 0.25
        fixed_time = prelude_sleep + countdown + post_countdown_sleep
        remaining = max(0.8, total_seconds - fixed_time)

        frames = max(8, min(24, int(remaining / 0.09)))
        frame_sleep = remaining / frames if frames > 0 else 0.08

        with _terminal_overlay():
            _move_home()
            _clear()
            print()
            print(_center(f"{ANSI_BRIGHT_GREEN}{ANSI_BOLD}{title}{ANSI_RESET}", width))
            print()
            print(_center(f"{ANSI_GREEN}Design: {design_name}{ANSI_RESET}", width))
            _sleep_or_break(prelude_sleep)

            _render_countdown(width=width, countdown=countdown, color=ANSI_BRIGHT_GREEN, title=title)
            _sleep_or_break(post_countdown_sleep)

            design_func(width, height, frames, frame_sleep)

    except KeyboardInterrupt:
        raise
    except Exception:
        try:
            _write(ANSI_RESET + ANSI_SHOW_CURSOR)
        except Exception:
            pass
        return


